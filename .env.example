# 複製這個檔案為 .env 並填入實際值（.env 已被 .gitignore 排除，不會進版控）

# Fine-grained personal access token
# 建立位置：https://github.com/settings/personal-access-tokens/new
# Resource owner 選你的 organization
# Organization permissions → 建議勾「Administration: Read and write」
# （Budgets API 為 public preview，若 403 可改試 classic token 的 admin:org scope）
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# Budget 所在的 organization 名稱
GITHUB_ORG=your-org-name

# 本機伺服器 port（選填，預設 3000）
PORT=3000

# Docker 對外 port（選填，預設 3002）— 與部署機其他服務衝突時改這個
# HOST_PORT=3002

# 每月內含 AI credits 總額（選填，正整數）— Included credits 卡片的分母
# 計算方式：Copilot 席數 × 每席內含額度
# 注意：usage-based billing 過渡期（至 2026-09-01）每席 3000 credits，之後降回 1900，屆時請手動更新
# 未設定時卡片只顯示已耗 credits、不畫比例 bar
INCLUDED_CREDITS=12000
